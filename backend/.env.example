# Copy to .env and fill in. The backend reads these at startup.
GCP_PROJECT=your-project-id
GCP_LOCATION=us-central1
BQ_DATASET=nestiq
GEMINI_MODEL=gemini-2.5-flash
# SERVER-ONLY Maps key: Air Quality, Places, Distance Matrix. Never sent to a browser.
# Restrict this key by API in the GCP console; it needs no referrer restriction.
MAPS_API_KEY=
# Browser Maps key, served by /api/config for the Maps JS SDK. This one IS public, so it
# MUST be HTTP-referrer restricted in the GCP console (nestiq-india.web.app + localhost)
# and limited to the Maps JavaScript API. Separating the keys stops the server key
# leaking; it is NOT protection on its own until that restriction is applied.
# If unset, /api/config returns "" and maps degrade rather than falling back.
MAPS_BROWSER_KEY=
# Comma-separated CORS allowlist. UNSET = localhost dev origins only (fail closed), so a
# deploy that forgets this breaks the frontend loudly instead of leaving the API open.
# Production value: https://nestiq-india.web.app
ALLOWED_ORIGINS=
# When true, the API serves deterministic mock data (no GCP calls). Auto-falls
# back to true if GCP credentials/tables are unavailable.
USE_MOCK=false
USE_ADK_ORCHESTRATION=false
